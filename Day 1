// Problem 6
//Alphabet case checker

#include<iostream>
using namespace std;

int main(){
    char ch;
    cin >> ch;

    bool isUpper = (ch >='A') && (ch <='Z');
    bool isLower = (ch >='a') && (ch <='z');

    cout<<"Upper case"<<isUpper<<endl;
    cout<<"Lower case"<<isLower<<endl;
    
    return 0;
}
