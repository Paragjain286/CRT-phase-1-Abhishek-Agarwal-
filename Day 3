// Problem 1
// Print 1 to 10 using FOR loop

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <=10; i++){
        cout<< i <<" ";
    }
}


// Problem 2
// Print EVEN numbers from 0 to 10

#include<iostream>
using namespace std;

int main(){
    
    for(int i = 0; i<=10; i += 2){
        cout <<i <<" ";
    }
}


// Problem 3
// Print 1 to 10 using WHILE loop

#include<iostream>
using namespace std;

int main(){
    int i = 1;
    while(i<=10){
        cout << i <<" ";
        i++;
    }
}


// Problem 4
// Print ODD numbers from 1 to 10

#include<iostream>
using namespace std;

int main(){
    int i = 1;
    while(i<=10){
        cout << i <<" ";
        i += 2;
    }
}


// Problem 5
// Print 1 to 10 using DO-WHILE loop

#include<iostream>
using namespace std;

int main(){
    int i = 1;
    do{
        cout<< i <<" ";
        i++;
    }while(i<=10);
}


// Problem 6
// Print FACTORIAL number using FOR loop

#include<iostream>
using namespace std;

int main(){
    int n;
    int fact = 1;
    cout << "Enter no...";
    cin >> n;
    
    for(int i = n; i>=1; i--){
        fact = fact * i;
}
    cout << fact;
}


// Problem 7
// Print PRIME NUMNBER CHECKER using FOR loop

#include<iostream>
using namespace std;

int main(){
    int n;
    cout << "Enter no...";
    cin >> n;
    
    for(int i = 2; i<n; i++){
        if(n % i == 0){
            cout << "IT is not Prime no.";
            break;
        }else{
            cout<<"Prime no...";
            break;
        }
    }
}


