//Problem 1
//Print no. from 1 to 5, 5 times

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i<=5; i++){
        for(int j = 1; j<=5; j++){
            cout << j;
        }
        cout <<"\n";
    }
}


//Problem 2
//Print solid square

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i<=5; i++){
        for(int j = 1; j<=5; j++){
            cout << "*";
        }
        cout <<"\n";
    }
}


