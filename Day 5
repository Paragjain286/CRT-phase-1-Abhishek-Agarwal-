// Problem 5
//Function Overloading

#include <iostream>
using namespace std;

int add(int a, int b){
    return a + b;
}
double add(double a, double b){
    return a + b;
}
int add(int a, int b, int c){
    return a + b + c;
}
float add(float a, float b, float c, float d){
    return a + b + c + d;
}

int main(){
    cout << add(5,2) << "\n";
    cout << add(4.3,4.2) << "\n";
    cout << add(5,3,2) << "\n";
    cout << add(4.3,2.2,4.1,5.8);
}
