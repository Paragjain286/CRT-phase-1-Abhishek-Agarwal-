// Problem 1
// Pattern Printing
#include<iostream>
using namespace std;

int main(){
    int n;
    cout << "Enter no...";
    cin >> n;
    //Upper Triangle
    for(int i = 1; i<=n; i++){
        for(int j = 1; j<=i; j++){
            cout << "*";
        }
        cout <<"\n";
    }
        //Lower Triangle
        for (int i = n-1; i>=1; i--){
            for(int j = 1; j<=i; j++){
                cout<< "*";
            }        
            cout<<"\n";
        }
}


